# Servidor de API (login)
JWT_SECRET=troque-por-uma-string-longa-e-secreta
JWT_EXPIRES_IN=7d
PORT=3001

# Firebase Admin — uma das opções:
# Caminho para o JSON da service account baixado do console Firebase
# FIREBASE_SERVICE_ACCOUNT_PATH=/caminho/para/serviceAccountKey.json
# ou variável de ambiente padrão do Google:
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/serviceAccountKey.json
# ou o JSON inteiro em uma linha (útil em CI):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Frontend (produção: URL pública da API)
# VITE_API_URL=https://sua-api.example.com
